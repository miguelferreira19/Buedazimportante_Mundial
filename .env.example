# Copia este ficheiro para ".env.local" (desenvolvimento) e preenche os valores.
# Na Vercel, define cada uma destas variaveis em Project Settings -> Environment Variables.

# --- Supabase (Project Settings -> API) ---
SUPABASE_URL=https://xxxxxxxx.supabase.co
# CHAVE SECRETA "service_role" (NUNCA a poias no frontend nem no GitHub)
SUPABASE_SERVICE_ROLE_KEY=

# --- Sessao (assina os cookies de login) ---
# Mete uma string longa e aleatoria. Gera uma com:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# --- football-data.org (resultados automaticos) ---
# Regista-te gratis em https://www.football-data.org/client/register e copia o token.
FOOTBALL_DATA_TOKEN=

# --- Cron (segredo partilhado com o GitHub Actions) ---
# Outra string aleatoria qualquer (diferente da SESSION_SECRET).
CRON_SECRET=

# --- Opcional: nome do site (aparece no topo) ---
NEXT_PUBLIC_SITE_NAME=Palpites Mundial 2026
